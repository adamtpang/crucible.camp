# ---- Resend (interest capture via the RSVP form) ----
# Without RESEND_API_KEY the /api/subscribe route runs in DEMO mode:
# it validates the email and returns success, but sends nothing.
RESEND_API_KEY=

# Optional: add each subscriber to a Resend Audience (Resend dashboard → Audiences)
RESEND_AUDIENCE_ID=

# Optional: get notified by email whenever someone joins
RSVP_NOTIFY_EMAIL=hello@crucible.camp

# Optional: verified sender. Defaults to Resend's test sender if unset.
RESEND_FROM="Crucible <hello@crucible.camp>"

# ---- QR script (scripts/generate-qr.mjs) ----
# Base URL the /door and /rsvp QR codes point at.
SITE_URL=https://crucible.camp
